<!DOCTYPE html>
<html lang="{{ settings.langattr | default('en') }}">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}{% endblock %}</title>

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="{{ meta.description|e }}" />
    <meta name="author" content="{{ meta.author|e }}" />
    <link rel="canonical" href="{{ item.urlAbs }}" />

    {{ assets.renderMeta() }}

    {% set defaultmode = (theme.defaultmode == 'darkmode') ? 'dark' : 'light' %}

    <script>

        /* Immediate Theme Application */
        (function() {
            // Get saved theme from localStorage, or use the default mode from the server
            const savedTheme = localStorage.getItem('theme') || '{{ defaultmode }}';

            // Apply the theme immediately
            document.documentElement.setAttribute('data-theme', savedTheme);

            // Save the theme to localStorage (if not already saved)
            if (!localStorage.getItem('theme')) {
                localStorage.setItem('theme', savedTheme);
            }
        })();

    </script>

    <style>
        :root {

            /* left column height */
            --leftColumnHeight: {{ theme.leftcolumnheight ? 'auto' : '100vh' }};

            /* Notices */
            --colorNotice1Border: {{ theme.colorNoticeGrayscale ? '#000' : '#f65a3c' }};
            --colorNotice1Text: {{ theme.colorNoticeGrayscale ? '#333' : '#333333' }};
            --colorNotice1Background: {{ theme.colorNoticeGrayscale ? '#fafafa' : '#ffded4' }};
            --colorNotice2Border: {{ theme.colorNoticeGrayscale ? '#999' : '#f6b73c' }};
            --colorNotice2Text: {{ theme.colorNoticeGrayscale ? '#333' : '#333333' }};
            --colorNotice2Background: {{ theme.colorNoticeGrayscale ? '#eee' : '#fff3d4' }};
            --colorNotice3Border: {{ theme.colorNoticeGrayscale ? '#ccc' : '#3c7bf6' }};
            --colorNotice3Text: {{ theme.colorNoticeGrayscale ? '#fff' : '#333333' }};
            --colorNotice3Background: {{ theme.colorNoticeGrayscale ? '#444' : '#d4e0ff' }};
            --colorNotice4Border: {{ theme.colorNoticeGrayscale ? '#000' : 'default-color-for-notice4-border' }};
            --colorNotice4Text: {{ theme.colorNoticeGrayscale ? '#fff' : 'default-color-for-notice4-text' }};
            --colorNotice4Background: {{ theme.colorNoticeGrayscale ? '#333' : 'default-color-for-notice4-background' }};

            /* Font Families */
            --font-body: {{ theme.font|default('-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen-Sans, Ubuntu, Cantarell, "Helvetica Neue", sans-serif') }};
            --font-headline: {{ theme.fontheadline|default('-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen-Sans, Ubuntu, Cantarell, "Helvetica Neue", sans-serif') }};

            /* Light Theme */
            --colorBrand: {{ theme.colorBrand|default('lightseagreen')|e }};

            --colorBodyBackground: {{ theme.colorBodyBackground|default('#ffffff')|e }};
            
            --colorLeftColumnBackground: {{ theme.colorLeftColumnBackground|default('#f5f5f5')|e }};
            --colorLeftColumnLinks: {{ theme.colorLeftColumnLinks|default('#333333')|e }};
            --colorLeftColumnHover: {{ theme.colorLeftColumnHover|default('#e0e0e0')|e }};
            
            --colorRightColumnBackground: {{ theme.colorRightColumnBackground|default('#ffffff')|e }};
            --colorRightColumnText: {{ theme.colorRightColumnText|default('#333333')|e }};
            --colorRightColumnLinks: {{ theme.colorRightColumnLinks|default('#007acc')|e }};
            
            --colorFooterBackground: {{ theme.colorFooterBackground|default('#333333')|e }};
            --colorFooterText: {{ theme.colorFooterText|default('#f5f5f5')|e }};
            --colorFooterLinks: {{ theme.colorFooterLinks|default('#00aced')|e }};
        }

        /* Dark Theme */
        [data-theme="dark"] {
            --colorBrand: {{ theme.colorBrandDark|default('teal')|e }};

            --colorBodyBackground: {{ theme.colorBodyBackgroundDark|default('#1a1a1a')|e }};
            
            --colorLeftColumnBackground: {{ theme.colorLeftColumnBackgroundDark|default('#333333')|e }};
            --colorLeftColumnLinks: {{ theme.colorLeftColumnLinksDark|default('#cccccc')|e }};
            --colorLeftColumnHover: {{ theme.colorLeftColumnHoverDark|default('#444444')|e }};
            
            --colorRightColumnBackground: {{ theme.colorRightColumnBackgroundDark|default('#1a1a1a')|e }};
            --colorRightColumnText: {{ theme.colorRightColumnTextDark|default('#e0e0e0')|e }};
            --colorRightColumnLinks: {{ theme.colorRightColumnLinksDark|default('#66c2ff')|e }};
            
            --colorFooterBackground: {{ theme.colorFooterBackgroundDark|default('#1a1a1a')|e }};
            --colorFooterText: {{ theme.colorFooterTextDark|default('#cccccc')|e }};
            --colorFooterLinks: {{ theme.colorFooterLinksDark|default('#66c2ff')|e }};
        }

    </style>

    {% set containersize = theme.containersize|default("w-full")|e %}
    {% set rightcolumnsize = theme.rightcolumnsize|default("mw8")|e %}

    {% block stylesheets %}

        <link rel="stylesheet" href="{{ base_url }}/themes/guide/css/tachyons.min.css">
        <link rel="stylesheet" href="{{ base_url }}/themes/guide/css/guide.css?20251103">

        {{ assets.renderCSS() }}

    {% endblock %}

</head>
<body>

    <svg style="position: absolute; width: 0; height: 0; overflow: hidden" version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
        <defs>
            <symbol id="icon-user" viewBox="0 0 20 28">
                <path d="M20 21.859c0 2.281-1.5 4.141-3.328 4.141h-13.344c-1.828 0-3.328-1.859-3.328-4.141 0-4.109 1.016-8.859 5.109-8.859 1.266 1.234 2.984 2 4.891 2s3.625-0.766 4.891-2c4.094 0 5.109 4.75 5.109 8.859zM16 8c0 3.313-2.688 6-6 6s-6-2.688-6-6 2.688-6 6-6 6 2.688 6 6z"></path>
            </symbol>
            <symbol id="icon-pencil" viewBox="0 0 32 32">
                <path d="M27 0c2.761 0 5 2.239 5 5 0 1.126-0.372 2.164-1 3l-2 2-7-7 2-2c0.836-0.628 1.874-1 3-1zM2 23l-2 9 9-2 18.5-18.5-7-7-18.5 18.5zM22.362 11.362l-14 14-1.724-1.724 14-14 1.724 1.724z"></path>
            </symbol>
            <symbol id="icon-printer" viewBox="0 0 32 32">
                <path d="M8 2h16v4h-16v-4z"></path>
                <path d="M30 8h-28c-1.1 0-2 0.9-2 2v10c0 1.1 0.9 2 2 2h6v8h16v-8h6c1.1 0 2-0.9 2-2v-10c0-1.1-0.9-2-2-2zM4 14c-1.105 0-2-0.895-2-2s0.895-2 2-2 2 0.895 2 2-0.895 2-2 2zM22 28h-12v-10h12v10z"></path>
            </symbol>
            <symbol id="icon-sun" viewBox="0 0 32 32">
                <path d="M16 26c1.105 0 2 0.895 2 2v2c0 1.105-0.895 2-2 2s-2-0.895-2-2v-2c0-1.105 0.895-2 2-2zM16 6c-1.105 0-2-0.895-2-2v-2c0-1.105 0.895-2 2-2s2 0.895 2 2v2c0 1.105-0.895 2-2 2zM30 14c1.105 0 2 0.895 2 2s-0.895 2-2 2h-2c-1.105 0-2-0.895-2-2s0.895-2 2-2h2zM6 16c0 1.105-0.895 2-2 2h-2c-1.105 0-2-0.895-2-2s0.895-2 2-2h2c1.105 0 2 0.895 2 2zM25.899 23.071l1.414 1.414c0.781 0.781 0.781 2.047 0 2.828s-2.047 0.781-2.828 0l-1.414-1.414c-0.781-0.781-0.781-2.047 0-2.828s2.047-0.781 2.828 0zM6.101 8.929l-1.414-1.414c-0.781-0.781-0.781-2.047 0-2.828s2.047-0.781 2.828 0l1.414 1.414c0.781 0.781 0.781 2.047 0 2.828s-2.047 0.781-2.828 0zM25.899 8.929c-0.781 0.781-2.047 0.781-2.828 0s-0.781-2.047 0-2.828l1.414-1.414c0.781-0.781 2.047-0.781 2.828 0s0.781 2.047 0 2.828l-1.414 1.414zM6.101 23.071c0.781-0.781 2.047-0.781 2.828 0s0.781 2.047 0 2.828l-1.414 1.414c-0.781 0.781-2.047 0.781-2.828 0s-0.781-2.047 0-2.828l1.414-1.414z"></path>
                <path d="M16 8c-4.418 0-8 3.582-8 8s3.582 8 8 8c4.418 0 8-3.582 8-8s-3.582-8-8-8zM16 21c-2.761 0-5-2.239-5-5s2.239-5 5-5 5 2.239 5 5-2.239 5-5 5z"></path>
            </symbol>
            <symbol id="icon-moon" viewBox="0 0 32 32">
                <path d="M13.502 5.414a15.075 15.075 0 0 0 11.594 18.194a11.113 11.113 0 0 1-7.975 3.39c-.138 0-.278.005-.418 0a11.094 11.094 0 0 1-3.2-21.584M14.98 3a1.002 1.002 0 0 0-.175.016a13.096 13.096 0 0 0 1.825 25.981c.164.006.328 0 .49 0a13.072 13.072 0 0 0 10.703-5.555a1.01 1.01 0 0 0-.783-1.565A13.08 13.08 0 0 1 15.89 4.38A1.015 1.015 0 0 0 14.98 3z" fill="currentColor"></path>
            </symbol>
            <symbol id="icon-menu" viewBox="0 0 20 20">
                <path d="M0 3h20v2h-20v-2zM0 9h20v2h-20v-2zM0 15h20v2h-20v-2z"></path>
            </symbol>
            <symbol id="icon-close" viewBox="0 0 20 20">
                <path d="M10 8.586l-7.071-7.071-1.414 1.414 7.071 7.071-7.071 7.071 1.414 1.414 7.071-7.071 7.071 7.071 1.414-1.414-7.071-7.071 7.071-7.071-1.414-1.414-7.071 7.071z"></path>
            </symbol>
       </defs>
    </svg>

    <!-- Main container with column flex for full screen height -->
    <div class="flex flex-column min-vh-100">

        <!-- Content Wrapper for Left and Right Columns -->
        <div class="flex-grow-1 flex w-100 {{ containersize }}">

            <!-- Left Column -->
            <aside id="left-column" class="left-column w-30 overflow-y-auto top-0">

                <div class="left-column-inner w6 pa3">

                    <!-- Logo and Switch -->
                    <div class="flex items-center justify-between pa3">
                        <div id="logo-container" class="flex items-center">
                            <a href="{{ home_url }}" class="dib v-mid no-underline hover-bg-transparent flex items-center">
                                {% if logo and theme.logoimg %}
                                    <img src="{{ base_url }}/{{ logo }}" alt="Logo" class="h2 mr2">
                                {% endif %}
                                {% if theme.logotext %}
                                    <span class="f3">{{ settings.title|e }}</span>
                                {% endif %}
                            </a>
                        </div>
                        <div id="collapse-icon" class="f5 mt1 pointer">
                            <svg class="icon icon-close"><use xlink:href="#icon-close"></use></svg>
                        </div>
                    </div>

                    <!-- Multilang -->
                    {% if multilang %}
                        <div class="langbar flex flex-wrap items-center pa3 mb0 mb0">
                            {% for lang,link in multilang %}
                                <a class="pa2 mr1 ba link" href="{{ base_url }}{{ link }}">{{ lang }}</a>
                            {% endfor %}
                        </div>
                    {% endif %}

                    <!-- Toolbar -->
                    <div class="toolbar flex flex-wrap items-center pa3 mb2 mb4-l">

                        {% if widgets %}
                            {% for index,widget in widgets %}
                                <div id="{{ index }}" class="toolbar-icon f4 mr3 mv2">
                                    {{ widget }}
                                </div>
                            {% endfor %}
                        {% endif %}

                        <span class="toolbar-icon f4 toggle-darkmode mr3 mv2">
                            <svg class="icon icon-sun pointer hidden"><use xlink:href="#icon-sun"></use></svg>
                            <svg class="icon icon-moon pointer hidden"><use xlink:href="#icon-moon"></use></svg>
                        </span>

                        {% if theme.print %}
                            <span class="toolbar-icon f4 mr3 mv2">
                                <a class="link" title="open printer dialogue" href="#" onclick="if (window.print) {window.print();}"><svg class="icon baseline icon-printer"><use xlink:href="#icon-printer"></use></svg></a>
                            </span>
                        {% endif %}
                        
                        {% if is_loggedin() %}

                            {% if theme.editorlink and is_allowed('content', 'edit') %}
                                <span class="toolbar-icon f4 mr3 mv2">
                                    <a class="link" title="switch to editor" href="{{ base_url }}/tm/content/visual{{ item.urlRelWoF }}"><svg class="icon baseline icon-pencil"><use xlink:href="#icon-pencil"></use></svg></a>
                                </span>
                            {% endif %}

                            <span class="toolbar-icon f4 mr3 mv2">
                                <a href="{{base_url}}/tm/account">
                                    <svg class="icon baseline icon-user"><use xlink:href="#icon-user"></use></svg>
                                </a>
                            </span>

                        {% endif %}

                    </div>

                    {% if theme.headernav %}
                        <div class="headernavi pa3 mb2 mb4-l dn-l">
                          <ul class="list ma0 pa0">
                            {% for label,url in theme.headernavitems %}
                            <li class="fw7 pv1 bl bw2 b--transparent">
                              <a href="{{ url }}" class="link dim f6 fw6">{{ label|e }}</a>
                            </li>
                            {% endfor %}
                          </ul>
                        </div>
                    {% endif %}

                    <!-- Navigation -->
                    <nav id="navigation" class="nav-list">
                    
                        {% include 'partials/navigation.twig' %}
                    
                    </nav>

                </div>
                <script>
                   /* initially open or close navigation */
                   (function() {
                        const folders = document.querySelectorAll(".folder");
                        folders.forEach(folder => {
                            const id = folder.getAttribute("data-id");
                            const isOpen = localStorage.getItem(`folder-${id}`) === "true";
                            const content = folder.querySelector("ul");

                            if (content) {
                                if (folder.classList.contains("active") || folder.classList.contains("activeParent")) {
                                    folder.classList.add("open");
                                } else if (isOpen) {
                                    folder.classList.add("open");
                                } else {
                                    folder.classList.remove("open");
                                }

                                // Ensure nested folders inside this folder are closed unless active
                                const nestedFolders = content.querySelectorAll(".folder");
                                nestedFolders.forEach(nestedFolder => {
                                    if (!nestedFolder.classList.contains("active") && !nestedFolder.classList.contains("activeParent")) {
                                        nestedFolder.classList.remove("open");
                                    }
                                });
                            }
                        });
                    })();                    
                </script>

            </aside>

            <!-- Main Wrapper -->
            <div class="right-column w-100">

                <div class="flex w-100 mb3 {% if theme.headernav %} headernavi {% endif %}">

                    <!-- Logo and Switch -->
                    <div class="sidebar-toggle {{ rightcolumnsize }} ph3 pv4 pb0-l flex justify-between w-100 w-auto-l">
                        <div id="logo-container" class="flex items-center hidden-l">
                            <a href="{{ base_url }}" class="dib v-mid no-underline hover-bg-transparent flex items-center">
                                {% if logo and theme.logoimg %}
                                    <img src="{{ base_url }}/{{ logo }}" alt="Logo" class="h2 mr2">
                                {% endif %}
                                {% if theme.logotext %}
                                    <span class="f3">{{ settings.title|e }}</span>
                                {% endif %}
                            </a>
                        </div>
                        <div id="expand-icon" class="expand-icon f5 pointer pv1 mt1">
                            <svg class="icon icon-menu"><use xlink:href="#icon-menu"></use></svg>
                        </div>
                    </div>

                    {% if theme.headernav %}
                        <div class="headerlinks flex-l w-100 justify-end pa4 dn db-l">
                          <ul class="list flex ma0 pa0">
                            {% for label,url in theme.headernavitems %}
                            <li class="mh2">
                              <a href="{{ url }}" class="link dim f6 fw6">{{ label|e }}</a>
                            </li>
                            {% endfor %}
                          </ul>
                        </div>
                    {% endif %}

                </div>

                <!-- Right Column (Main Content with Sticky Navigation) -->
                <main class="w-100 {{ rightcolumnsize }} pa3 ph4-l pt0-l flex-l center">
                    <!-- Main Content -->
                    {% block content %}{% endblock %}
                    
                </main>

            </div>

        </div>

        <footer class="w-100 bt tc">

            {% include 'partials/footer.twig' %}

        </footer>

    </div>

        {% block javascripts %}

            <script src="{{ base_url }}/themes/guide/js/guide.js?20251103"></script>

            {{ assets.renderJS() }}

        {% endblock %}

</body>
</html>