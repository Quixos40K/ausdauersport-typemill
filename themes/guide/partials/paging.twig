{% if item.prevItem or item.nextItem %}

	<div id="bottompager" class="f5 pv3 flex-l flex-m justify-between">
		{% if item.prevItem %}
			<a class="underline-off link w-100 w-40-l w-40-m mv1 pv2 ph3 ba dim dib" href="{{ item.prevItem.urlRel }}">&lsaquo;&nbsp; {{ item.prevItem.name|e }}</a>
		{% endif %}
		{% if item.nextItem %}
			<a class="underline-off link w-100 w-40-l w-40-m mv1 pv2 ph3 dib ba dim tr" href="{{ item.nextItem.urlRel }}">{{ item.nextItem.name|e }} &nbsp;&rsaquo;</a>
		{% endif %}
	</div>

{% endif %}
