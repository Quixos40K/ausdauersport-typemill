    {
      "@type": "DefinedTerm",
      "@id": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/trainingsintensitaeten/pyramidal-training/#pyramidal-training",
      "url": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/trainingsintensitaeten/pyramidal-training/",
      "name": "Pyramidal Training",
      "alternateName": [
        "Pyramidales Training",
        "Pyramiden-Modell"
      ],
      "termCode": "PYR",
      "description": "Pyramidal Training ist ein Belastungsverteilungs-Modell im Ausdauersport. Es strukturiert die Intensität wie eine Pyramide: Der größte Teil wird locker trainiert (Basis), ein kleinerer Anteil moderat und der kleinste Anteil hochintensiv (Spitze).",
      "subjectOf": {
        "@id": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/trainingsintensitaeten/pyramidal-training/#article"
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/trainingsintensitaeten/pyramidal-training/#faq",
      "url": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/trainingsintensitaeten/pyramidal-training/#haeufige-fragen-zum-pyramidal-training",
      "name": "Häufige Fragen zum Pyramidal Training",
      "inLanguage": "de-DE",
      "isPartOf": {
        "@id": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/trainingsintensitaeten/pyramidal-training/#webpage"
      },
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Was ist der Unterschied zwischen pyramidalem und polarisiertem Training?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Beide Modelle setzen als Basis auf einen hohen Anteil an sehr lockerem Training. Beim polarisierten Training wird der mittlere Intensitätsbereich jedoch gemieden, während das pyramidale Training ihn gezielt und kontrolliert für die Leistungsentwicklung einsetzt."
          }
        },
        {
          "@type": "Question",
          "name": "Ist pyramidales Training besser als polarisiertes Training?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Es gibt kein pauschal besseres Modell. Pyramidales Training eignet sich häufig besonders gut für wettkampfspezifische Phasen (wie z. B. Marathon- oder Halbmarathontraining), in denen die mittlere Schwellen-Intensität dem Zieltempo entspricht."
          }
        },
        {
          "@type": "Question",
          "name": "Wie sieht die Intensitätsverteilung beim pyramidalen Training aus?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Die Verteilung ähnelt einer Pyramide: Die breite Basis bilden lockere Grundlagenläufe. Der mittlere Teil besteht aus dosierten, moderaten Einheiten, und die Spitze bilden wenige, stark kontrollierte hochintensive Reize."
          }
        },
        {
          "@type": "Question",
          "name": "Bedeutet pyramidales Training, dass ich in der Grauzone laufe?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Nein. Grauzonentraining entsteht, wenn lockere Läufe ungewollt zu schnell werden. Im pyramidalen Modell wird der mittlere Intensitätsbereich (Moderate Intensity) ganz gezielt, fokussiert und geplant eingesetzt, nicht aus Versehen."
          }
        },
        {
          "@type": "Question",
          "name": "Kann man die Modelle im Jahresverlauf mischen?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ja, das ist in der modernen Trainingssteuerung die Regel. Viele Athleten starten im Winter mit einem polarisierten Modell für aerobe Kapazität und VO2max und wechseln in der direkten Wettkampfvorbereitung zu einem pyramidalen Modell, um die Tempohärte an der Schwelle auszubauen."
          }
        }
      ]
    },
