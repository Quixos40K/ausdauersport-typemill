    {
      "@type": "FAQPage",
      "@id": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/trainingsintensitaeten/moderate-intensity/#faq",
      "url": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/trainingsintensitaeten/moderate-intensity/#haeufige-fragen-zu-mit",
      "name": "Häufige Fragen zu MIT (Moderate Intensity Training)",
      "inLanguage": "de-DE",
      "isPartOf": {
        "@id": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/trainingsintensitaeten/moderate-intensity/#webpage"
      },
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Was bedeutet MIT im Ausdauertraining?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "MIT steht für Moderate Intensity Training und beschreibt Ausdauertraining mit mittlerer Intensität. Die Belastung ist spürbar fordernd, aber noch kontrollierbar."
          }
        },
        {
          "@type": "Question",
          "name": "In welcher Zone liegt MIT?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "In typischen 5-Zonen-Modellen entspricht MIT meist Zone 3 bzw. dem Bereich zwischen der ersten aeroben und der zweiten anaeroben Schwelle."
          }
        },
        {
          "@type": "Question",
          "name": "Welche Anpassungen bewirkt MIT?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "MIT stärkt die Schwellenleistung, verbessert die Laktatverarbeitung unter Belastung und entwickelt die Fähigkeit, ein höheres Wettkampftempo länger aufrechtzuerhalten."
          }
        },
        {
          "@type": "Question",
          "name": "Warum wird vor zu viel MIT gewarnt?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Wird der mittlere Bereich zu dominant, erzeugt er hohe Restermüdung, ohne die maximale Sauerstoffaufnahme wie HIIT zu reizen oder die Regeneration wie LIT zu ermöglichen."
          }
        },
        {
          "@type": "Question",
          "name": "Was ist der Unterschied zwischen MIT und LIT?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "LIT (Low Intensity) ist sehr locker und regenerationsarm, während MIT (Moderate Intensity) eine deutliche, vertiefte Atmung und höhere muskuläre Beanspruchung erzeugt."
          }
        },
        {
          "@type": "Question",
          "name": "Ist Schwellentraining dasselbe wie MIT?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Schwellentraining liegt meist am oberen Ende des MIT-Bereichs (nahe der anaeroben Schwelle) und stellt eine spezifische, sehr effektive Form moderater Intensität dar."
          }
        },
        {
          "@type": "Question",
          "name": "Wann ist MIT im Trainingsplan sinnvoll?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gezielte MIT-Einheiten sind besonders in der spezifischen Wettkampfvorbereitung (z. B. für Halbmarathon oder Marathon) wertvoll, um das geplante Renntempo zu festigen."
          }
        },
        {
          "@type": "Question",
          "name": "Woran erkennt man MIT beim Laufen?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Die Atmung ist vertieft, eine Unterhaltung ist nur noch in kurzen Sätzen möglich und das Tempo verlangt kontinuierliche mentale Konzentration."
          }
        }
      ]
    },
