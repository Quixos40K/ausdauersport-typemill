      "hasDefinedTerm": [
        {
          "@type": "DefinedTerm",
          "@id": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/trainingsintensitaeten/zone-1-5/#zone-1",
          "name": "Zone 1",
          "termCode": "Z1",
          "description": "Sehr lockere Intensität für Regeneration, Einlaufen, Auslaufen und sehr leichte Grundlageneinheiten."
        },
        {
          "@type": "DefinedTerm",
          "@id": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/trainingsintensitaeten/zone-1-5/#zone-2",
          "name": "Zone 2",
          "termCode": "Z2",
          "description": "Ruhiger aerober Bereich für Grundlagenausdauer, längere Belastungen und größere Trainingsumfänge bei vergleichsweise geringer Ermüdung."
        },
        {
          "@type": "DefinedTerm",
          "@id": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/trainingsintensitaeten/zone-1-5/#zone-3",
          "name": "Zone 3",
          "termCode": "Z3",
          "description": "Moderate, kontrollierbare Intensität für Tempodauerläufe und längere spezifische Belastungen."
        },
        {
          "@type": "DefinedTerm",
          "@id": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/trainingsintensitaeten/zone-1-5/#zone-4",
          "name": "Zone 4",
          "termCode": "Z4",
          "description": "Hohe, häufig schwellennahe Intensität zur Entwicklung von Schwellenleistung, Wettkampftempo und Tempohärte."
        },
        {
          "@type": "DefinedTerm",
          "@id": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/trainingsintensitaeten/zone-1-5/#zone-5",
          "name": "Zone 5",
          "termCode": "Z5",
          "description": "Sehr hohe bis maximale Intensität für kurze Intervalle und starke Reize auf maximale Sauerstoffaufnahme und Leistungsfähigkeit."
        }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/trainingsintensitaeten/zone-1-5/#faq",
      "url": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/trainingsintensitaeten/zone-1-5/#haeufige-fragen-zu-den-zonen-1-5",
      "name": "Häufige Fragen zu den Zonen 1–5",
      "inLanguage": "de",
      "isPartOf": {
        "@id": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/trainingsintensitaeten/zone-1-5/#webpage"
      },
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Was bedeutet Zone 1 bis 5 im Ausdauertraining?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Zone 1 bis 5 beschreibt unterschiedliche Intensitätsbereiche im Ausdauertraining. Zone 1 ist sehr locker, Zone 2 ruhig aerob, Zone 3 moderat, Zone 4 schwellennahe Belastung und Zone 5 hochintensiv."
          }
        },
        {
          "@type": "Question",
          "name": "Welche Zone ist für Grundlagenausdauer wichtig?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Für die Grundlagenausdauer sind vor allem Zone 1 und Zone 2 wichtig. Besonders Zone 2 wird häufig genutzt, um die aerobe Basis, den Fettstoffwechsel und die Belastungsverträglichkeit zu verbessern."
          }
        },
        {
          "@type": "Question",
          "name": "Warum sollte nicht jedes Training hart sein?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Harte Einheiten setzen starke Reize, erzeugen aber auch viel Ermüdung. Wenn zu oft hart trainiert wird, fehlt dem Körper die Erholung, um sich anzupassen. Fortschritt entsteht durch das Verhältnis aus Belastung und Regeneration."
          }
        },
        {
          "@type": "Question",
          "name": "Ist Zone 3 schlecht?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Zone 3 ist nicht grundsätzlich schlecht. Sie wird problematisch, wenn sie unbewusst zu häufig trainiert wird und dadurch viel Ermüdung erzeugt, ohne dass lockere oder intensive Einheiten ihre volle Wirkung entfalten."
          }
        },
        {
          "@type": "Question",
          "name": "Wofür ist Zone 4 sinnvoll?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Zone 4 dient vor allem dazu, Schwellenleistung und Tempohärte zu verbessern und ein hohes Tempo über längere Zeit kontrolliert aufrechtzuerhalten."
          }
        },
        {
          "@type": "Question",
          "name": "Wofür ist Zone 5 sinnvoll?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Zone 5 wird für sehr intensive Reize genutzt, meist in Intervallen. Sie kann die maximale Sauerstoffaufnahme, die neuromuskuläre Aktivierung und die Leistungsfähigkeit bei hohen Intensitäten verbessern."
          }
        },
        {
          "@type": "Question",
          "name": "Wie bestimme ich meine Trainingszonen?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Trainingszonen können über Herzfrequenz, Pace, Watt, Laktat, Atemverhalten oder subjektives Belastungsempfinden bestimmt werden. Individuelle Tests sind genauer, während Atmung und Belastungsgefühl im Alltag zusätzliche Orientierung geben."
          }
        },
        {
          "@type": "Question",
          "name": "Sind Trainingszonen exakt?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Nein. Trainingszonen sind Orientierungshilfen mit fließenden Übergängen. Tagesform, Müdigkeit, Hitze, Stress, Schlaf, Ernährung und Gelände können die wahrgenommene und gemessene Intensität beeinflussen."
          }
        },
        {
          "@type": "Question",
          "name": "Welche Zone sollte ich am meisten trainieren?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Bei vielen Ausdauersportlern liegt der größte Trainingsanteil im niedrigen Intensitätsbereich, vor allem in Zone 1 und Zone 2. Die genaue Verteilung hängt von Ziel, Leistungsstand, Trainingsumfang und Regenerationsfähigkeit ab."
          }
        }
      ]
    },
