    {
      "@type": "FAQPage",
      "@id": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/trainingsintensitaeten/low-intensity-training/#faq",
      "url": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/trainingsintensitaeten/low-intensity-training/#haeufige-fragen-zum-lit-low-intensity-training",
      "name": "Häufige Fragen zum LIT (Low Intensity Training)",
      "inLanguage": "de",
      "isPartOf": {
        "@id": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/trainingsintensitaeten/low-intensity-training/#webpage"
      },
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Was bedeutet LIT im Ausdauertraining?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "LIT steht für Low Intensity Training und beschreibt Training mit niedriger Intensität. Die Belastung ist locker, kontrolliert und über längere Zeit gut durchhaltbar."
          }
        },
        {
          "@type": "Question",
          "name": "In welcher Zone liegt LIT?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "LIT liegt je nach Zonenmodell meist in Zone 1 bis Zone 2. Entscheidend ist, dass die Belastung niedrig bleibt und nicht unbewusst in den moderaten Bereich rutscht."
          }
        },
        {
          "@type": "Question",
          "name": "Warum ist LIT wichtig?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "LIT verbessert die aerobe Grundlage, unterstützt den Fettstoffwechsel, fördert die Belastungsverträglichkeit und ermöglicht regelmäßiges Training mit geringerer Ermüdung."
          }
        },
        {
          "@type": "Question",
          "name": "Ist LIT nur für Anfänger sinnvoll?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Nein. LIT ist auch für fortgeschrittene und leistungsorientierte Ausdauersportler wichtig. Es bildet die Grundlage, auf der intensivere Trainingsreize besser verarbeitet werden können."
          }
        },
        {
          "@type": "Question",
          "name": "Kann man mit LIT schneller werden?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ja, indirekt. LIT verbessert die aerobe Basis und Belastbarkeit. Dadurch können später intensivere Einheiten besser umgesetzt und verkraftet werden."
          }
        },
        {
          "@type": "Question",
          "name": "Warum sollte LIT nicht zu hart sein?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Wenn LIT zu intensiv wird, entsteht unnötige Ermüdung. Die Einheit ist dann nicht mehr wirklich locker und kann die Erholung sowie die Qualität späterer harter Einheiten beeinträchtigen."
          }
        },
        {
          "@type": "Question",
          "name": "Woran erkenne ich LIT?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "LIT fühlt sich locker und kontrolliert an. Die Atmung bleibt ruhig, eine Unterhaltung ist meist möglich und die Einheit sollte nicht das Gefühl einer harten Belastung hinterlassen."
          }
        },
        {
          "@type": "Question",
          "name": "Ist LIT dasselbe wie Regenerationstraining?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Nicht immer. LIT kann regenerativ wirken, wenn es sehr locker und passend dosiert ist. Längere LIT-Einheiten können aber trotz niedriger Intensität eine relevante Trainingsbelastung darstellen."
          }
        },
        {
          "@type": "Question",
          "name": "Wie oft sollte man LIT trainieren?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Das hängt von Trainingsziel, Leistungsstand, Umfang und Regeneration ab. In vielen Ausdauerprogrammen macht LIT einen großen Teil des Trainings aus, weil es gut verkraftbar ist und langfristige Anpassungen unterstützt."
          }
        }
      ]
    },
