    {
      "@type": "DefinedTerm",
      "@id": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/periodisierung/makrozyklus/#makrozyklus",
      "url": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/periodisierung/makrozyklus/",
      "name": "Makrozyklus",
      "alternateName": [
        "Saisonplanung",
        "Langfristige Trainingsplanung"
      ],
      "termCode": "MACRO",
      "description": "Ein Makrozyklus ist die langfristigste Planungseinheit in der Trainingsperiodisierung. Er strukturiert das Training über mehrere Monate oder eine gesamte Saison hinweg in sinnvolle Phasen, um ein oder mehrere Trainingsziele zu erreichen.",
      "subjectOf": {
        "@id": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/periodisierung/makrozyklus/#article"
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/periodisierung/makrozyklus/#faq",
      "url": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/periodisierung/makrozyklus/#haeufige-fragen-zum-makrozyklus",
      "name": "Häufige Fragen zum Makrozyklus",
      "inLanguage": "de-DE",
      "isPartOf": {
        "@id": "https://www.oliver-nix.de/ausdauersport/trainingswissenschaft/periodisierung/makrozyklus/#webpage"
      },
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Was ist ein Makrozyklus einfach erklärt?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ein Makrozyklus ist der langfristige Rahmen eines Trainingsplans. Er bündelt die gesamte Vorbereitung auf ein Ziel und dauert meist mehrere Monate oder eine ganze Saison."
          }
        },
        {
          "@type": "Question",
          "name": "Wie lange dauert ein Makrozyklus?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Die Dauer ist flexibel und hängt vom Ziel ab. Typische Makrozyklen im Ausdauersport dauern zwischen 12 Wochen für ein spezifisches Event und bis zu einem ganzen Jahr für die Saisonplanung."
          }
        },
        {
          "@type": "Question",
          "name": "Was ist der Unterschied zwischen Makrozyklus, Mesozyklus und Mikrozyklus?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Der Makrozyklus ist der gesamte Plan. Er besteht aus mehreren Mesozyklen (mehrwöchigen Trainingsblöcken), die wiederum aus Mikrozyklen (einzelnen Trainingswochen) aufgebaut sind."
          }
        }
      ]
    },
